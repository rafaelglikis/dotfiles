{
  "$schema": "https://opencode.ai/config.json",
  "watcher": {
    "ignore": [
      ".idea/**",
      ".git/**",
      ".vscode/**",
      "node_modules/**",
      "dist/**",
      "vendor/**",
      "venv/**",
      ".venv/**",
      "__pycache__/**",
